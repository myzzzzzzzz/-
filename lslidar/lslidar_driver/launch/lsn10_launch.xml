<launch>
  <arg name="use_sim_time" default="false"/>
  <arg name="serial_port" default="/dev/ttyACM1"/>
  <node pkg="lslidar_driver" exec="lslidar_driver_node" name="lslidar_driver_node" output="screen" emulate_tty="true">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param from="$(env ORIGINCAR_SRC)/lslidar/lslidar_driver/params/lidar_uart_ros2/lsn10.yaml"/>
    <param name="serial_port_" value="$(var serial_port)"/>
  </node>
</launch>
